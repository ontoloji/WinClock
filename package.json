{
  "name": "winclock",
  "version": "1.0.0",
  "description": "Windows 11 desktop clock app with transparent UI, tray, and custom fonts",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:detached": "node start-detached.js",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.ontoloji.winclock",
    "productName": "WinClock",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
